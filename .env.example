# ═══════════════════════════════════════════════════════════════════════════
# SMDApp — Environment Variables Template
#
# 1. Copy this file to `.env`:   cp .env.example .env
# 2. Replace every REPLACE_WITH_* / placeholder with a real value.
# 3. NEVER commit `.env` — it contains secrets and is git-ignored.
#    This `.env.example` file contains ONLY placeholders and is safe to commit.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database (Prisma + SQLite) ──────────────────────────────────────────────
# SQLite file path. Use an absolute path in production.
DATABASE_URL="file:/home/sachin/Desktop/SMDApp/db/custom.db"
# Optional raw DB path used by some helpers.
DB_PATH="/home/sachin/Desktop/SMDApp/db/custom.db"

# ─── Auth.js (next-auth v5) ─────────────────────────────────────────────────
# Secret used to encrypt session tokens. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
# Google OAuth credentials — create at:
#   https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="REPLACE_WITH_GOOGLE_CLIENT_SECRET"
# Base URL of THIS app. Local default shown; set to your production domain.
AUTH_URL="http://localhost:3000"

# ─── ICICI Breeze API ───────────────────────────────────────────────────────
# Get credentials from https://api.icicidirect.com/breezeapi
BREEZE_APP_KEY="REPLACE_WITH_BREEZE_APP_KEY"
BREEZE_SECRET_KEY="REPLACE_WITH_BREEZE_SECRET_KEY"
# Session token is generated at runtime; leave blank unless you supply one.
BREEZE_SESSION_TOKEN=""
BREEZE_USERNAME="REPLACE_WITH_BREEZE_USERNAME"
BREEZE_PASSWORD="REPLACE_WITH_BREEZE_PASSWORD"
# Public (browser-exposed) app key — safe to ship to the client.
NEXT_PUBLIC_BREEZE_API_KEY="REPLACE_WITH_BREEZE_APP_KEY"

# ─── Telegram Bot (alerts) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="REPLACE_WITH_TELEGRAM_BOT_TOKEN"
TELEGRAM_CHAT_ID="REPLACE_WITH_TELEGRAM_CHAT_ID"
TELEGRAM_DAILY_CHAT_ID="REPLACE_WITH_TELEGRAM_DAILY_CHAT_ID"
# Comma-separated list of chat IDs that receive the daily digest.
TELEGRAM_DIGEST_CHAT_IDS="REPLACE_WITH_CHAT_ID_1,REPLACE_WITH_CHAT_ID_2"
# Allow alerts to fire outside market hours (true / false).
TELEGRAM_ALLOW_OFFHOURS="false"

# ─── LLM / AI providers ──────────────────────────────────────────────────────
GROQ_API_KEY="REPLACE_WITH_GROQ_API_KEY"
OPENROUTER_API_KEY="REPLACE_WITH_OPENROUTER_API_KEY"
# Optional providers — unused by default, supported if you configure them.
DEEPSEEK_API_KEY=""
NVIDIA_API_KEY=""

# ─── Internal API secrets ─────────────────────────────────────────────────────
API_SECRET_KEY="REPLACE_WITH_API_SECRET_KEY"
API_SECRET="REPLACE_WITH_API_SECRET"
# Shared secret used to authenticate the daily-scan cron job.
DAILY_SCAN_SECRET="REPLACE_WITH_DAILY_SCAN_SECRET"

# ─── Service / sidecar URLs ──────────────────────────────────────────────────
# Trade Audit engine (sidecar, port 4001)
NEXT_PUBLIC_TRADE_AUDIT_URL="http://localhost:4001"
# Market History engine (sidecar, port 4002)
NEXT_PUBLIC_MARKET_HISTORY_URL="http://localhost:4002"
# Market Recorder URL (same sidecar as Market History)
NEXT_PUBLIC_MARKET_RECORDER_URL="http://localhost:4002"
# Public base URL of this Next.js app (used by client + server fetch calls).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Internal API base used by server-side code.
INTERNAL_API_BASE="http://localhost:3000"
SMDAPP_API_BASE="http://localhost:3000"
# Legacy Nuxt client base (unused by the Next.js app).
NUXT_PUBLIC_API_BASE="http://localhost:3000"

# ─── Sidecar / service configuration ────────────────────────────────────────
# Market History sidecar
MARKET_HISTORY_DB="/home/sachin/Desktop/SMDApp/db/market-history.db"
MARKET_HISTORY_PORT="4002"
# Main app / server port
PORT="3000"
# Backtest data source: "breeze" (real) | "simulated"
BACKTEST_DATA_SOURCE="breeze"
# Recorder tick mode: "realtime" | "batch"
RECORDER_MODE="realtime"
# Comma-separated symbols the recorder tracks.
RECORDER_SYMBOLS="NIFTY,BANKNIFTY,FINNIFTY,MIDCPNIFTY,SENSEX"
# Default brokerage fees per trade (used in P&L calculation).
DEFAULT_FEES_PER_TRADE="20"

# ─── Misc ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
