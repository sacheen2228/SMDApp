[Unit]
Description=SMDApp Next.js API Server (port 3000)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/sachin/Desktop/SMDApp
ExecStart=/home/sachin/.bun/bin/bun x next dev -p 3000
Restart=always
RestartSec=10
TimeoutStopSec=30
Environment=NODE_ENV=development

[Install]
WantedBy=default.target
